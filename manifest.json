{
  "manifest_version": 3,
  "name": "Deskfy Extrator",
  "version": "1.2",
  "description": "Extrai solicitações do Deskfy para CSV sem erros de CORS. Funciona em popup e no GitHub Pages.",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://service-api.deskfy.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "app.html",
    "default_title": "Abrir Deskfy Extrator"
  },
  "content_scripts": [
    {
      "matches": ["https://nfbrentano.github.io/deskfyExtrator/*"],
      "js": ["content.js"]
    }
  ],
  "externally_connectable": {
    "matches": [
      "https://nfbrentano.github.io/*"
    ]
  },
  "icons": {
    "128": "assets/icon128.png"
  }
}
